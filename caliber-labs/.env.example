# Copy to .env.local and fill in real values (never commit .env.local).

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YeyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxkY21va2F5dmNzb29hZWxjbGNwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM5Mjk4MzMsImV4cCI6MjA4OTUwNTgzM30.feJDNfvSFWU56Bc2q-fiCjoXG8kSurppOLkDEBhtQb4OUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY  # For server-side only

# Required for Prisma + Supabase (Settings → Database → Connection string → URI).
# If your DB password contains # $ ! or @, wrap the whole URI in quotes and URL-encode the password
# (e.g. ! → %21, # → %23, $ → %24) or dotenv may break the line / drop DATABASE_URL.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# WooCommerce (optional)
# WOOCOMMERCE_URL=
# WOOCOMMERCE_CONSUMER_KEY=
# WOOCOMMERCE_CONSUMER_SECRET=

# NextAuth (add when you set up login)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=
